# ── LibreLinkUp ──────────────────────────────
# Your LibreLink / LibreLinkUp login credentials
LIBRE_EMAIL=your@email.com
LIBRE_PASSWORD=yourpassword
LIBRE_REGION=EU          # EU or US depending on where you registered

# ── Twilio ────────────────────────────────────
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_auth_token
TWILIO_PHONE_FROM=+1xxxxxxxxxx          # Your Twilio phone number (for voice calls)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886  # Twilio sandbox number (keep this as-is for now)

# ── Web Push (VAPID) ─────────────────────────
# Generate these by visiting /api/push/vapid-keys once your server is running
VAPID_PUBLIC=your_vapid_public_key
VAPID_PRIVATE=your_vapid_private_key
VAPID_EMAIL=mailto:your@email.com

# ── Alarm defaults (optional, can be set via app) ──
GLUCOSE_THRESHOLD=60
LOW_DURATION_MINS=30
ALARM_GAP_MINS=15
WA_WINDOW_MINS=5
CALL_ATTEMPTS=2
CALL_GAP_SECS=30
